# OpenRouter — used with the cheap "openrouter/auto" model to generate explanations.
# Create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=

# Upstash Redis (REST) — stores cached explanations, the "latest searches" list,
# and powers per-IP + global daily rate limiting. Create a free DB at https://console.upstash.com
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Optional rate-limit tuning (sensible defaults are baked in).
# New generations allowed per IP per day:
RATE_LIMIT_PER_IP_PER_DAY=20
# Total NEW generations allowed across all users per day (the wallet guard):
RATE_LIMIT_GLOBAL_PER_DAY=1000

# Public base URL, used for canonical/OG tags and the sitemap.
NEXT_PUBLIC_SITE_URL=https://siteexplainer.com

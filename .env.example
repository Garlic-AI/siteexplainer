# OpenRouter — generation uses the free auto-router "openrouter/free" by default,
# so there is no per-request cost and OpenRouter's free-tier limits are the rate
# limiter. Create a key at https://openrouter.ai/keys
OPENROUTER_API_KEY=
# Optional: pin a specific model instead of the free auto-router, e.g.
# "meta-llama/llama-3.3-70b-instruct:free" or a paid model like "openrouter/auto".
# OPENROUTER_MODEL=openrouter/free

# Upstash Redis (REST) — caches explanations and the "latest explained" list.
# Create a free DB at https://console.upstash.com . The app still runs without it
# (it just won't cache).
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=

# Public base URL, used for canonical/OG tags and the sitemap.
NEXT_PUBLIC_SITE_URL=https://www.siteexplainer.com
